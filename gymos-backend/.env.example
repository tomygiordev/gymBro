# Environment Configuration
NODE_ENV=development
PORT=3000

# SQLite database file used for local development
DATABASE_URL=./data/gymos.db

# JWT
JWT_SECRET=gymos-local-dev-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Password hashing cost
ARGON_SALT_LENGTH=3

# CORS
CORS_ORIGINS=*
